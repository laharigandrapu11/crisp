# Controls what `gcloud builds submit` uploads as the build context.
# Mirrors .dockerignore so we don't upload datasets, notebooks, caches, etc.
#
# Without this file, gcloud falls back to .gitignore (or uploads EVERYTHING
# if there isn't one), which can balloon the upload to multiple GB.

.gcloudignore
.git
.gitignore
.gitkeep

.DS_Store
.env
.venv

**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.mypy_cache
**/.ipynb_checkpoints

# Notebooks and training-only assets are not needed at serving time.
**/*.ipynb
denoising/data/
recognition/data/
segmentation/test_output/

# Local artefacts that should never end up in the build context.
*.log
*.tmp
